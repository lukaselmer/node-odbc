{
  "name": "@lukaselmer/odbc",
  "description": "unixodbc bindings for node",
  "version": "2.5.1",
  "homepage": "https://github.com/lukaselmer/node-odbc",
  "main": "lib/odbc.js",
  "types": "lib/odbc.d.ts",
  "files": [
    "src/",
    "lib/",
    "CHANGELOG.md",
    "binding.gyp"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/lukaselmer/node-odbc.git"
  },
  "bugs": {
    "url": "https://github.com/lukaselmer/node-odbc/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "contributors": [
    {
      "name": "Mark Irish",
      "email": "mirish@ibm.com"
    },
    {
      "name": "Dan VerWeire",
      "email": "dverweire@gmail.com"
    },
    {
      "name": "Lee Smith",
      "email": "notwink@gmail.com"
    }
  ],
  "license": "MIT",
  "directories": {
    "lib": "."
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node-pre-gyp install --build-from-source",
    "install": "node-pre-gyp install --fallback-to-build",
    "test": "mocha --slow 5000 --timeout 30000"
  },
  "dependencies": {
    "@mapbox/node-pre-gyp": "^2.0.0",
    "async": "^3.2.6"
  },
  "gypfile": true,
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "dotenv": "^17.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "mocha": "^11.7.4",
    "node-addon-api": "^8.6.0"
  },
  "binary": {
    "module_name": "odbc",
    "module_path": "./lib/bindings/napi-v{napi_build_version}",
    "host": "https://github.com/lukaselmer/node-odbc/releases/download/v{version}",
    "package_name": "odbc-v{version}-{platform}-{arch}-napi-v{napi_build_version}.tar.gz",
    "napi_versions": [
      8
    ]
  }
}
